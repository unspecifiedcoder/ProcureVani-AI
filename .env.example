# .env.example
# Copy this file to .env and fill in your credentials.

# -- WhatsApp Business Cloud API --
# Register at https://developers.facebook.com
# Create a WhatsApp Business App to get these values.
WA_VERIFY_TOKEN=procurevani_verify_secret_2026
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=

# -- Google Gemini LLM --
# Get your key at https://ai.google.dev
GEMINI_API_KEY=

# -- Supabase (Postgres) --
# Create a project at https://supabase.com
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# -- Redis (Session Cache) --
# Leave as localhost for local dev; Upstash URL for production.
REDIS_URL=redis://localhost:6379

# -- IPFS / Pinata --
# Create an account at https://www.pinata.cloud
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud

# -- Polygon Blockchain --
# Use Amoy testnet for development.
# Get testnet MATIC from https://faucet.polygon.technology
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
PRIVATE_KEY=
CONTRACT_ADDRESS=

# -- Application --
ENVIRONMENT=development
BASE_URL=http://localhost:8000
